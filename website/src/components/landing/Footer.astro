---
---

<footer class="relative py-14 px-6 border-t border-border overflow-hidden">
  <!-- Thin orange gradient line at top -->
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-orange/20 to-transparent" aria-hidden="true"></div>

  <div class="max-w-[1280px] mx-auto flex flex-col items-center gap-6 text-center">

    <!-- Brand -->
    <div class="flex items-center gap-2 font-mono text-[0.8125rem]">
      <span class="text-orange text-[0.625rem]" aria-hidden="true">◆</span>
      <span class="text-ink-2 font-semibold">create-ruxum-app</span>
      <span class="text-ink-4 text-[0.6875rem]">v0.1.0</span>
    </div>

    <!-- Nav links -->
    <nav class="flex items-center gap-0.5 flex-wrap justify-center" aria-label="Footer navigation">
      <a href="/introduction"
         class="px-2.5 py-1 font-mono text-[0.75rem] text-ink-3 no-underline hover:text-ink-2 transition-colors duration-150">
        docs
      </a>
      <a href="/installation"
         class="px-2.5 py-1 font-mono text-[0.75rem] text-ink-3 no-underline hover:text-ink-2 transition-colors duration-150">
        install
      </a>
      <a href="/scaffold/fullstack"
         class="px-2.5 py-1 font-mono text-[0.75rem] text-ink-3 no-underline hover:text-ink-2 transition-colors duration-150">
        full-stack
      </a>
      <a href="https://github.com/AndresFritscheOgando/ruxum"
         target="_blank" rel="noopener noreferrer"
         class="px-2.5 py-1 font-mono text-[0.75rem] text-ink-3 no-underline hover:text-ink-2 transition-colors duration-150">
        github ↗
      </a>
      <a href="https://www.npmjs.com/package/create-ruxum-app"
         target="_blank" rel="noopener noreferrer"
         class="px-2.5 py-1 font-mono text-[0.75rem] text-ink-3 no-underline hover:text-ink-2 transition-colors duration-150">
        npm ↗
      </a>
    </nav>

    <!-- Divider -->
    <div class="w-16 h-px bg-border-2" aria-hidden="true"></div>

    <!-- Credit + license -->
    <div class="flex flex-col items-center gap-1.5">
      <p class="text-[0.8125rem] text-ink-4">
        Inspired by
        <a href="https://create.t3.gg" target="_blank" rel="noopener noreferrer"
           class="text-ink-3 no-underline hover:text-ink-2 transition-colors duration-150">
          create-t3-app
        </a>.
        Built with
        <a href="https://astro.build" target="_blank" rel="noopener noreferrer"
           class="text-ink-3 no-underline hover:text-ink-2 transition-colors duration-150">
          Astro
        </a>.
      </p>
      <p class="font-mono text-[0.6875rem] text-ink-4">MIT License</p>
    </div>

  </div>
</footer>
