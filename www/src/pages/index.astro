---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/landing/Hero.astro';
import TechStack from '../components/landing/TechStack.astro';
import Features from '../components/landing/Features.astro';
---

<BaseLayout
  title="create-ruxum-app — Scaffold Rust + Next.js at terminal velocity"
  description="The fastest way to scaffold a production-ready full-stack application with a Rust/Axum API and Next.js frontend. One command, your choices, done."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "create-ruxum-app",
      "description": "The fastest way to scaffold a production-ready full-stack application with a Rust/Axum API and Next.js frontend.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "macOS, Linux, Windows",
      "url": "https://create-ruxum-app.vercel.app",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "create-ruxum-app",
      "url": "https://create-ruxum-app.vercel.app",
      "logo": "https://create-ruxum-app.vercel.app/favicon.svg",
      "sameAs": [
        "https://github.com/AndresFritscheOgando/ruxum",
        "https://www.npmjs.com/package/create-ruxum-app"
      ]
    })} />
  </Fragment>
  <main>
    <Hero />
    <TechStack />
    <Features />
  </main>
</BaseLayout>
