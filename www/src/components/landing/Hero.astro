---
import { Image } from "astro:assets";
import houston from "../../assets/houston.webp";
import CopyCommand from "./CopyCommand";
import TerminalWizard from "../TerminalWizard";
---

<section class="relative overflow-hidden px-8 pt-36 pb-28 border-b border-border">

  <!-- Warm-tinted CRT grid with bottom fade -->
  <div class="crt-grid-warm crt-grid--faded absolute inset-0 pointer-events-none" aria-hidden="true"></div>
  <!-- CRT scanlines -->
  <div class="crt-scanlines absolute inset-0 pointer-events-none z-[1]" aria-hidden="true"></div>
  <!-- Bottom gradient fade into next section -->
  <div class="absolute bottom-0 inset-x-0 h-16 bg-gradient-to-t from-canvas to-transparent pointer-events-none z-[3]" aria-hidden="true"></div>

  <div class="hero-grid relative z-[2] max-w-[1200px] mx-auto grid grid-cols-2 gap-14 items-center">

    <!-- Left: content -->
    <div>

      <!-- Headline: sans-serif, mixed-case, confident -->
      <h1 class="headline-fluid font-sans font-semibold leading-[1.08] tracking-[-0.03em] text-ink mb-6">
        Scaffold Rust&nbsp;+&nbsp;Next.js<br />
        <span class="text-orange">in one command.</span>
      </h1>

      <!-- Supporting copy: two lines max -->
      <p class="text-[1.0625rem] leading-[1.7] text-ink-2 max-w-[460px] mb-10">
        Production-ready Rust/Axum backend and Next.js frontend,
        wired together from a single interactive prompt.
      </p>

      <!-- CopyCommand as the focused install CTA -->
      <div class="mb-6">
        <CopyCommand client:load />
      </div>

      <!-- Single secondary text link -->
      <a href="/introduction"
         class="inline-flex items-center gap-1.5 font-sans text-[0.875rem] text-ink-3 no-underline
                hover:text-ink transition-colors duration-150">
        Read the docs
        <span aria-hidden="true" class="text-orange">→</span>
      </a>

    </div>

    <!-- Right: terminal demo — clean border, no glow -->
    <div class="w-full relative rounded-xl overflow-hidden border border-border-2
                [box-shadow:0_16px_48px_rgba(0,0,0,0.5)]">
      <TerminalWizard client:visible />
      <Image
        src={houston}
        alt="Houston, the Astro mascot, giving a thumbs up"
        width={64}
        height={64}
        loading="eager"
        fetchpriority="high"
        class="absolute -bottom-8 -right-8 opacity-50 hover:opacity-80 transition-opacity duration-300"
      />
    </div>

  </div>
</section>

<style>
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; gap: 3rem; }
    section { padding-top: 4rem; padding-bottom: 3.5rem; }
  }
  @media (max-width: 480px) {
    section { padding-left: 1.25rem; padding-right: 1.25rem; padding-top: 3rem; }
    .hero-grid > div:last-child { max-width: 100%; }
  }
</style>
