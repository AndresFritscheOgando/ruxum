---
import CopyCommand from "./CopyCommand";
import TerminalWizard from "../TerminalWizard";
---

<section class="relative overflow-hidden px-6 pt-24 pb-20 border-b border-border">

  <!-- Phosphor green grid with bottom fade -->
  <div class="crt-grid crt-grid--faded absolute inset-0 pointer-events-none" aria-hidden="true"></div>
  <!-- CRT scanlines -->
  <div class="crt-scanlines absolute inset-0 pointer-events-none z-[1]" aria-hidden="true"></div>
  <!-- Ambient orange glow — sits behind right column -->
  <div class="hero-ambient absolute top-1/2 right-[8%] -translate-y-1/2 z-[1]" aria-hidden="true"></div>

  <div class="hero-grid relative z-[2] max-w-[1280px] mx-auto grid grid-cols-2 gap-16 items-center">

    <!-- Left: content -->
    <div>
      <!-- Badge with left orange accent -->
      <div class="inline-flex items-center gap-2 px-3 py-1 mb-7
                  border border-border-2 border-l-2 border-l-orange bg-surface
                  font-mono text-[0.6875rem] text-ink-3 uppercase tracking-[0.08em]">
        <span class="text-orange text-[0.625rem]" aria-hidden="true">◆</span>
        scaffold at terminal velocity
      </div>

      <!-- Headline -->
      <h1 class="headline-fluid font-mono font-semibold leading-[1.05] tracking-[-0.02em] text-ink mb-6">
        SCAFFOLD<br />
        RUST + NEXT.JS<br />
        <span class="text-orange [text-shadow:0_0_40px_rgba(244,67,54,0.4)]">APPS FAST</span>
      </h1>

      <!-- Description -->
      <p class="text-[1.0625rem] leading-[1.65] text-ink-2 max-w-[480px] mb-8">
        The fastest way to build a production-ready full-stack app with a
        <span class="text-orange">Rust/Axum backend</span> and a
        <span class="text-green-dim">Next.js frontend</span>.
        One command. Your choices. Zero boilerplate.
      </p>

      <!-- Actions -->
      <div class="flex flex-col items-start gap-5">
        <CopyCommand client:load />
        <div class="flex items-center gap-3 flex-wrap">
          <a href="/introduction"
             class="inline-flex items-center gap-2 px-5 py-2.5 rounded-none no-underline
                    font-mono text-[0.8125rem] tracking-[0.04em] lowercase text-white
                    bg-orange border border-orange
                    shadow-[0_0_20px_rgba(244,67,54,0.35)]
                    hover:shadow-[0_0_40px_rgba(244,67,54,0.55)] hover:bg-[#e53935]
                    hover:-translate-y-px
                    focus:outline-none focus:ring-2 focus:ring-orange/50
                    transition-all duration-200">
            get started <span aria-hidden="true">→</span>
          </a>
          <a href="https://github.com/AndresFritscheOgando/ruxum"
             target="_blank"
             rel="noopener noreferrer"
             class="inline-flex items-center gap-2 px-5 py-2.5 rounded-none no-underline
                    font-mono text-[0.8125rem] tracking-[0.04em] lowercase text-ink-2
                    border border-border-2 bg-transparent
                    hover:border-orange/30 hover:bg-orange/[0.04] hover:text-ink
                    transition-all duration-200">
            view on github <span aria-hidden="true">↗</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Right: terminal demo -->
    <div class="relative">
      <!-- Subtle top gradient ring around terminal -->
      <div class="absolute -inset-[1px] bg-gradient-to-b from-orange/[0.07] via-transparent to-transparent pointer-events-none z-[-1]" aria-hidden="true"></div>
      <TerminalWizard client:load />
    </div>

  </div>
</section>

<style>
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; gap: 3rem; }
    section { padding-top: 4rem; padding-bottom: 3.5rem; }
    .hero-ambient { display: none; }
  }
  @media (max-width: 480px) {
    section { padding-left: 1rem; padding-right: 1rem; padding-top: 3rem; }
  }
</style>
