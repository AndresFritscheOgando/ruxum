---
---

<footer class="relative px-8 pt-20 pb-0 overflow-hidden border-t border-border">

  <!-- Gradient line at very top -->
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-orange/40 to-transparent" aria-hidden="true"></div>

  <!-- Ambient glow — bumped to 0.08 so it reads as a warm anchor -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-20 bg-orange/[0.08] blur-[64px] rounded-full pointer-events-none" aria-hidden="true"></div>

  <!-- CRT grid background -->
  <div class="absolute inset-0 crt-grid opacity-[0.3] pointer-events-none" aria-hidden="true"></div>

  <!-- Large faint watermark — raised to 0.035 so it reads as intentional -->
  <div class="absolute bottom-8 right-4 font-mono font-semibold text-[6rem] leading-none text-ink/[0.035] select-none pointer-events-none tracking-[-0.04em]" aria-hidden="true">
    RUXUM
  </div>

  <div class="relative max-w-[1200px] mx-auto">

    <!-- Body grid: wide brand col + two nav cols -->
    <div class="footer-grid grid gap-16 pb-14 border-b border-border">

      <!-- Col 1: Brand -->
      <div class="flex flex-col gap-6">

        <!-- Logo mark -->
        <div class="flex items-center gap-2.5 font-mono">
          <span class="w-[0.4375rem] h-[0.4375rem] rounded-full bg-green shrink-0 animate-indicator-pulse
                       [box-shadow:0_0_10px_rgba(0,255,65,0.9),0_0_3px_rgba(0,255,65,0.6)]"></span>
          <span class="text-[0.9375rem] font-semibold text-ink tracking-[-0.01em]">create-ruxum-app</span>
          <span class="font-mono text-[0.5625rem] text-ink-4 border border-border-2 rounded px-1.5 py-0.5 leading-none">v0.1.0</span>
        </div>

        <!-- Tagline -->
        <p class="font-mono text-[0.8125rem] text-ink-3 leading-[1.7] max-w-[300px]">
          Scaffold a production&#8209;ready <span class="text-orange">Rust&thinsp;/&thinsp;Axum</span> +
          <span class="text-green-dim">Next.js</span> app in a single terminal command.
        </p>

        <!-- Handcrafted note -->
        <p class="font-mono text-[0.6875rem] text-ink-4 leading-none">
          made with care &mdash; open source &amp; free forever
        </p>

        <!-- Install command block -->
        <div class="flex items-center gap-3 bg-ink/[0.05] border border-border-2 rounded-md px-4 py-2.5 w-fit
                    hover:border-orange/30 hover:bg-orange/[0.03] transition-colors duration-200 group cursor-default">
          <span class="font-mono text-[0.625rem] text-ink-4 select-none">$</span>
          <code class="font-mono text-[0.8125rem] text-orange tracking-[-0.01em] group-hover:[text-shadow:0_0_20px_rgba(244,67,54,0.4)] transition-all duration-200">npx create-ruxum-app</code>
        </div>

        <!-- Status pills -->
        <div class="flex items-center gap-4 font-mono text-[0.625rem]">
          <div class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-green/80 [box-shadow:0_0_6px_rgba(0,255,65,0.5)]"></span>
            <span class="text-green/80 uppercase tracking-[0.06em]">stable</span>
          </div>
          <span class="w-px h-3 bg-border-2"></span>
          <span class="text-ink-4 uppercase tracking-[0.08em]">MIT License</span>
          <span class="w-px h-3 bg-border-2"></span>
          <span class="text-ink-4 uppercase tracking-[0.08em]">open source</span>
        </div>

      </div>

      <!-- Col 2: Docs navigation -->
      <div class="flex flex-col gap-5">
        <div class="pb-2.5 border-b border-border">
          <span class="font-mono text-[0.625rem] uppercase tracking-[0.14em] text-orange/70">
            <span class="text-orange/50" aria-hidden="true">◆</span>
            &ensp;Documentation
          </span>
        </div>
        <nav class="flex flex-col gap-2.5" aria-label="Documentation links">
          <a href="/introduction"
             class="group flex items-center gap-2.5 font-mono text-[0.8125rem] text-ink-3 no-underline
                    hover:text-ink transition-colors duration-150 w-fit">
            <span class="text-border-2 group-hover:text-orange group-hover:translate-x-1 transition-all duration-150 text-[0.5rem]">▸</span>
            Introduction
          </a>
          <a href="/installation"
             class="group flex items-center gap-2.5 font-mono text-[0.8125rem] text-ink-3 no-underline
                    hover:text-ink transition-colors duration-150 w-fit">
            <span class="text-border-2 group-hover:text-orange group-hover:translate-x-1 transition-all duration-150 text-[0.5rem]">▸</span>
            Installation
          </a>
          <a href="/scaffold/rust"
             class="group flex items-center gap-2.5 font-mono text-[0.8125rem] text-ink-3 no-underline
                    hover:text-ink transition-colors duration-150 w-fit">
            <span class="text-border-2 group-hover:text-orange group-hover:translate-x-1 transition-all duration-150 text-[0.5rem]">▸</span>
            Rust Axum API
          </a>
          <a href="/scaffold/nextjs"
             class="group flex items-center gap-2.5 font-mono text-[0.8125rem] text-ink-3 no-underline
                    hover:text-ink transition-colors duration-150 w-fit">
            <span class="text-border-2 group-hover:text-orange group-hover:translate-x-1 transition-all duration-150 text-[0.5rem]">▸</span>
            Next.js App
          </a>
          <a href="/scaffold/fullstack"
             class="group flex items-center gap-2.5 font-mono text-[0.8125rem] text-ink-3 no-underline
                    hover:text-ink transition-colors duration-150 w-fit">
            <span class="text-border-2 group-hover:text-orange group-hover:translate-x-1 transition-all duration-150 text-[0.5rem]">▸</span>
            Full&#8209;stack
          </a>
        </nav>
      </div>

      <!-- Col 3: Project links -->
      <div class="flex flex-col gap-5">
        <div class="pb-2.5 border-b border-border">
          <span class="font-mono text-[0.625rem] uppercase tracking-[0.14em] text-orange/70">
            <span class="text-orange/50" aria-hidden="true">◆</span>
            &ensp;Project
          </span>
        </div>
        <div class="flex flex-col gap-2.5">
          <a href="https://github.com/AndresFritscheOgando/ruxum"
             target="_blank" rel="noopener noreferrer"
             class="group flex items-center gap-2.5 font-mono text-[0.8125rem] text-ink-3 no-underline
                    hover:text-orange transition-colors duration-150 w-fit">
            <span class="text-border-2 group-hover:text-orange group-hover:translate-x-1 transition-all duration-150 text-[0.5rem]">▸</span>
            GitHub
            <svg class="w-2.5 h-2.5 opacity-35 group-hover:opacity-75 -translate-y-px transition-opacity" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M1.5 8.5l7-7M3.5 1.5h6v6"/>
            </svg>
          </a>
          <a href="https://www.npmjs.com/package/create-ruxum-app"
             target="_blank" rel="noopener noreferrer"
             class="group flex items-center gap-2.5 font-mono text-[0.8125rem] text-ink-3 no-underline
                    hover:text-orange transition-colors duration-150 w-fit">
            <span class="text-border-2 group-hover:text-orange group-hover:translate-x-1 transition-all duration-150 text-[0.5rem]">▸</span>
            npm
            <svg class="w-2.5 h-2.5 opacity-35 group-hover:opacity-75 -translate-y-px transition-opacity" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M1.5 8.5l7-7M3.5 1.5h6v6"/>
            </svg>
          </a>
          <a href="https://create.t3.gg"
             target="_blank" rel="noopener noreferrer"
             class="group flex items-center gap-2.5 font-mono text-[0.8125rem] text-ink-3 no-underline
                    hover:text-ink-2 transition-colors duration-150 w-fit">
            <span class="text-border-2 group-hover:text-ink-3 group-hover:translate-x-1 transition-all duration-150 text-[0.5rem]">▸</span>
            <span>create&#8209;t3&#8209;app</span>
            <svg class="w-2.5 h-2.5 opacity-35 group-hover:opacity-75 -translate-y-px transition-opacity" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M1.5 8.5l7-7M3.5 1.5h6v6"/>
            </svg>
          </a>
        </div>
      </div>

    </div>

    <!-- Bottom status bar -->
    <div class="flex items-center justify-between py-5">

      <div class="flex items-center gap-3 font-mono text-[0.625rem] text-ink-4">
        <span class="text-orange/40" aria-hidden="true">◆</span>
        <span class="text-ink-3">© 2025 create-ruxum-app</span>
        <span class="text-border-3" aria-hidden="true">·</span>
        <span>MIT License</span>
      </div>

      <div class="flex items-center gap-2 font-mono text-[0.625rem] text-ink-4">
        <span>Built with</span>
        <a href="https://astro.build" target="_blank" rel="noopener noreferrer"
           class="text-ink-3 no-underline hover:text-ink transition-colors duration-150">Astro</a>
        <span class="text-ink-4" aria-hidden="true">/</span>
        <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer"
           class="text-ink-3 no-underline hover:text-ink transition-colors duration-150">Tailwind</a>
        <span class="text-ink-4" aria-hidden="true">/</span>
        <span>React</span>
        <span class="w-px h-3 bg-border-2 mx-1" aria-hidden="true"></span>
        <span class="text-ink-4">crafted with ♥</span>
      </div>

    </div>

  </div>
</footer>

<style>
  footer .footer-grid {
    grid-template-columns: 2fr 1fr 1fr;
  }
  @media (max-width: 900px) {
    footer .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
    footer .footer-grid > *:first-child {
      grid-column: span 2;
    }
  }
  @media (max-width: 600px) {
    footer .footer-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    footer .footer-grid > *:first-child {
      grid-column: span 1;
    }
    footer {
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }
  }
</style>
