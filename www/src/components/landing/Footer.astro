---
import pkg from "../../../../package.json";
---

<footer class="ts-footer">
  <!-- The Forge Glow - matching Hero and other sections -->
  <div class="footer-glow-container" aria-hidden="true">
    <div class="footer-glow-main"></div>
  </div>

  <!-- CRT grid background -->
  <div class="absolute inset-0 crt-grid opacity-[0.2] pointer-events-none" aria-hidden="true"></div>

  <!-- Large faint watermark - refined for Industrial Forge -->
  <div class="footer-watermark" aria-hidden="true">
    RUXUM
  </div>

  <div class="footer-inner">

    <!-- Body grid -->
    <div class="footer-grid">

      <!-- Col 1: Brand -->
      <div class="footer-brand">

        <!-- Logo mark -->
        <div class="footer-logo">
          <span class="w-1.5 h-1.5 rounded-full bg-green animate-indicator-pulse"></span>
          <span class="footer-logo-text font-mono">create-ruxum-app</span>
          <span class="terminal-badge lowercase">v{pkg.version}</span>
        </div>

        <!-- Tagline -->
        <p class="footer-tagline">
          Scaffold a production-ready <span class="text-orange">Rust&thinsp;/&thinsp;Axum</span> +
          <span class="text-green">Next.js</span> application in a single terminal command.
        </p>


        <!-- Install command block - Refined with machined style -->
        <div class="footer-install-block group">
          <span class="font-mono text-[0.625rem] text-ink-4 select-none">$</span>
          <code class="footer-install-code font-mono">npx create-ruxum-app</code>
        </div>

        <!-- Status pills -->
        <div class="footer-status-row font-mono">
          <div class="flex items-center gap-1.5">
            <span class="w-1 h-1 rounded-full bg-green/80 shadow-[0_0_6px_var(--color-green)]"></span>
            <span class="text-green/80 uppercase tracking-widest text-[0.5625rem]">stable version</span>
          </div>
          <span class="footer-status-divider"></span>
          <span class="uppercase tracking-widest text-[0.5625rem]">MIT License</span>
          <span class="footer-status-divider"></span>
          <span class="uppercase tracking-widest text-[0.5625rem]">Open Source</span>
        </div>

      </div>

      <!-- Col 2: Docs navigation -->
      <div class="footer-nav-col">
        <div class="footer-nav-header">
          <span class="footer-nav-label font-mono">
            <span class="text-orange/60" aria-hidden="true">◆</span>
            Documentation
          </span>
        </div>
        <nav class="footer-nav-links" aria-label="Documentation links">
          <a href="/docs/introduction" class="footer-nav-link font-mono">
            <span class="footer-nav-bullet">▸</span> Introduction
          </a>
          <a href="/docs/installation" class="footer-nav-link font-mono">
            <span class="footer-nav-bullet">▸</span> Installation
          </a>
          <a href="/docs/scaffold/rust" class="footer-nav-link font-mono">
            <span class="footer-nav-bullet">▸</span> Rust Axum API
          </a>
          <a href="/docs/scaffold/nextjs" class="footer-nav-link font-mono">
            <span class="footer-nav-bullet">▸</span> Next.js Application
          </a>
          <a href="/docs/scaffold/fullstack" class="footer-nav-link font-mono">
            <span class="footer-nav-bullet">▸</span> Full&#8209;stack
          </a>
        </nav>
      </div>

      <!-- Col 3: Project links -->
      <div class="footer-nav-col">
        <div class="footer-nav-header">
          <span class="footer-nav-label font-mono">
            <span class="text-orange/60" aria-hidden="true">◆</span>
            Project
          </span>
        </div>
        <div class="footer-nav-links">
          <a href="https://github.com/AndresFritscheOgando/ruxum" target="_blank" rel="noopener noreferrer" class="footer-nav-link font-mono group">
            <span class="footer-nav-bullet">▸</span> GitHub
            <svg class="footer-link-icon" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M1.5 8.5l7-7M3.5 1.5h6v6"/>
            </svg>
          </a>
          <a href="https://www.npmjs.com/package/create-ruxum-app" target="_blank" rel="noopener noreferrer" class="footer-nav-link font-mono group">
            <span class="footer-nav-bullet">▸</span> npm
            <svg class="footer-link-icon" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M1.5 8.5l7-7M3.5 1.5h6v6"/>
            </svg>
          </a>
        </div>
      </div>

    </div>

    <!-- Bottom status bar -->
    <div class="footer-bottom-bar">
      <div class="footer-copyright font-mono">
        <span class="text-orange/40" aria-hidden="true">◆</span>
        <span>© 2026 create-ruxum-app</span>
        <span class="footer-status-divider"></span>
        <span>Built with ♥ for the Rust ecosystem</span>
      </div>

      <div class="footer-tech-stack font-mono">
        <span class="text-ink-4">Built with</span>
        <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>
        <span class="text-ink-4">/</span>
        <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer">Tailwind</a>
        <span class="text-ink-4">/</span>
        <span>React</span>
      </div>
    </div>

  </div>
</footer>

<style>
  .ts-footer {
    position: relative;
    padding: 8rem 1.5rem 4rem;
    background: var(--color-canvas);
    border-top: 1px solid var(--color-border);
    overflow: hidden;
  }

  .footer-inner {
    position: relative;
    max-width: 1100px;
    margin: 0 auto;
    z-index: 10;
  }

  .footer-glow-container {
    position: absolute;
    top: 0;
    left: 50%;
    width: 100%;
    height: 300px;
    pointer-events: none;
    z-index: 0;
  }

  .footer-glow-main {
    position: absolute;
    top: -150px;
    left: 50%;
    width: 800px;
    height: 300px;
    background: radial-gradient(ellipse at center, var(--color-orange-embers) 0%, transparent 70%);
    transform: translateX(-50%);
    animation: forge-glow 12s ease-in-out infinite;
  }

  .footer-watermark {
    position: absolute;
    bottom: -0.1em;
    right: -0.1em;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 12rem;
    line-height: 1;
    color: var(--color-ink);
    opacity: 0.02;
    letter-spacing: -0.05em;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 4rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid var(--color-border-2);
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .footer-logo-text {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: -0.02em;
  }

  .footer-tagline {
    font-size: 0.8125rem;
    color: var(--color-ink-3);
    line-height: 1.8;
    max-width: 320px;
    margin-bottom: 1.5rem;
  }

  .footer-install-block {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border-2);
    padding: 0.625rem 1rem;
    border-radius: 6px;
    width: fit-content;
    margin-bottom: 1.5rem;
    box-shadow: inset 0 1px 0 0 var(--color-glass-hi);
    transition: all 0.2s ease;
  }

  .footer-install-block:hover {
    border-color: var(--color-orange-dim);
    background: var(--color-surface-2);
  }

  .footer-install-code {
    font-size: 0.8125rem;
    color: var(--color-orange);
    transition: text-shadow 0.2s ease;
  }

  .footer-install-block:hover .footer-install-code {
    text-shadow: 0 0 12px var(--color-orange-molten);
  }

  .footer-status-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-ink-4);
  }

  .footer-status-divider {
    width: 1px;
    height: 0.75rem;
    background: var(--color-border-2);
  }

  .footer-nav-header {
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border-2);
  }

  .footer-nav-label {
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-ink-3);
  }

  .footer-nav-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-nav-link {
    font-size: 0.8125rem;
    color: var(--color-ink-3);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: fit-content;
    transition: all 0.15s ease;
  }

  .footer-nav-link:hover {
    color: var(--color-ink);
  }

  .footer-nav-bullet {
    font-size: 0.5rem;
    color: var(--color-border-3);
    transition: all 0.15s ease;
  }

  .footer-nav-link:hover .footer-nav-bullet {
    color: var(--color-orange);
    transform: translateX(2px);
  }

  .footer-link-icon {
    width: 0.625rem;
    height: 0.625rem;
    opacity: 0.3;
    transition: opacity 0.15s ease;
  }

  .footer-nav-link:hover .footer-link-icon {
    opacity: 0.8;
  }

  .footer-bottom-bar {
    padding-top: 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .footer-copyright {
    font-size: 0.625rem;
    color: var(--color-ink-4);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-tech-stack {
    font-size: 0.625rem;
    color: var(--color-ink-3);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-tech-stack a {
    color: var(--color-ink-2);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-tech-stack a:hover {
    color: var(--color-ink);
  }

  @media (max-width: 800px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .footer-tagline { max-width: none; }
  }

  @media (max-width: 480px) {
    .ts-footer { padding: 5rem 1.5rem 3rem; }
    .footer-bottom-bar { flex-direction: column; align-items: flex-start; }
  }
</style>
