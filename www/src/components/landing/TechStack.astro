---
const scaffoldTypes = [
  {
    label: "RUST API",
    description: "A production-ready Axum web server with async handlers, typed errors, and structured logging.",
    items: ["axum", "tokio", "sqlx / seaorm", "jwt (optional)"],
    featured: false,
  },
  {
    label: "NEXT.JS APP",
    description: "A full Next.js 15 application with App Router, TypeScript, and optional Tailwind CSS.",
    items: ["next.js 15", "typescript", "tailwind (optional)"],
    featured: false,
  },
  {
    label: "FULL-STACK",
    description: "Both together — a Rust/Axum API and a Next.js frontend, wired up and ready to ship.",
    items: ["axum + next.js", "sqlx / seaorm", "jwt auth", "typescript"],
    featured: true,
  },
];

const technologies = [
  { name: "axum",       tagline: "Ergonomic async Rust web framework built on Tokio and Tower." },
  { name: "next.js",    tagline: "React framework with App Router, SSR, and streaming." },
  { name: "sqlx",       tagline: "Compile-time checked SQL queries. No ORM overhead." },
  { name: "seaorm",     tagline: "Async, dynamic ORM for Rust. An alternative to SQLx." },
  { name: "postgresql", tagline: "The world's most advanced open-source relational database." },
  { name: "mysql",      tagline: "High-performance, widely-used relational database." },
  { name: "sqlite",     tagline: "Zero-config embedded database. Perfect for development." },
  { name: "jwt auth",   tagline: "Stateless authentication tokens. Full middleware included." },
];
---

<section class="ts-section">
  <div class="ts-inner">

    <!-- Divider & Header -->
    <div class="ts-divider"></div>
    
    <div class="ts-header">
      <div class="ts-badge">
        <span class="ts-badge__icon" aria-hidden="true">◆</span>
        <span class="ts-badge__text">The Stack</span>
      </div>
      <h2 class="ts-headline text-gradient-forge">Everything you need.</h2>
      <p class="ts-description">
        Pick the pieces. Skip the rest. Every choice is made in the interactive
        wizard — no config files, no guesswork.
      </p>
    </div>

    <!-- Scaffold Grid -->
    <div class="scaffold-grid">
      {scaffoldTypes.map((type) => (
        <div class={`machined-card scaffold-card ${type.featured ? 'scaffold-card--featured' : ''}`}>
          {type.featured && (
            <div class="scaffold-card__featured-badge">★ recommended</div>
          )}
          
          <div class="scaffold-card__label font-mono">{type.label}</div>
          <p class="scaffold-card__description">{type.description}</p>
          
          <ul class="scaffold-card__list">
            {type.items.map((item) => (
              <li class="scaffold-card__list-item font-mono">
                <span class="ts-orange-dot">◆</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Tech Divider -->
    <div class="ts-tech-header">
      <div class="ts-badge">
        <span class="ts-green-dash" aria-hidden="true">—</span>
        <h3 class="ts-badge__text">TECHNOLOGIES INCLUDED</h3>
      </div>
    </div>

    <!-- Tech Grid -->
    <div class="tech-grid">
      {technologies.map((tech) => (
        <div class="machined-card tech-card">
          <div class="tech-card__title font-mono">
            <span class="ts-orange-dot">◆</span>
            {tech.name}
          </div>
          <p class="tech-card__tagline">{tech.tagline}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .ts-section {
    padding: 10rem 3rem;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-canvas);
    position: relative;
    overflow: hidden;
  }

  /* Subtle ambient glow for the section background */
  .ts-section::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 1000px;
    height: 600px;
    background: radial-gradient(ellipse at center, var(--color-orange-embers) 0%, transparent 70%);
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 0;
  }

  .ts-inner {
    position: relative;
    max-width: 860px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    z-index: 1;
  }

  .ts-divider {
    width: 100%;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--color-border-2), transparent);
    margin-bottom: 6rem;
  }

  .ts-header {
    margin-bottom: 5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .ts-badge {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 1.25rem;
  }

  .ts-badge__icon {
    color: var(--color-orange);
    font-size: 0.75rem;
    filter: drop-shadow(0 0 8px var(--color-orange-molten));
  }

  .ts-green-dash {
    color: var(--color-green);
    font-size: 0.75rem;
  }

  .ts-badge__text {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-ink-4);
  }

  .ts-headline {
    font-family: var(--font-sans);
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 1.25rem;
  }

  .ts-description {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--color-ink-2);
    max-width: 540px;
  }

  /* Scaffold Cards */
  .scaffold-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    width: 100%;
    margin-bottom: 6rem;
  }

  .scaffold-card {
    position: relative;
    border-radius: 12px;
    padding: 3rem 1.75rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .scaffold-card--featured {
    border-color: var(--color-orange-dim);
    box-shadow: 
      inset 0 1px 0 0 var(--color-glass-hi),
      0 0 40px -10px var(--color-orange-embers);
  }

  .scaffold-card__featured-badge {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--color-orange);
    color: #fff;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 600;
    padding: 0.25rem 0.875rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    box-shadow: 0 4px 12px var(--color-orange-embers);
    pointer-events: none;
  }

  .scaffold-card__label {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-ink);
    margin-bottom: 1.25rem;
    letter-spacing: 0.02em;
  }

  .scaffold-card__description {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-ink-3);
    margin-bottom: 2.5rem;
    flex-grow: 1;
  }

  .scaffold-card__list {
    list-style: none;
    padding: 1.5rem 0 0;
    margin: 0;
    border-top: 1px solid var(--color-border-2);
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .scaffold-card__list-item {
    font-size: 0.75rem;
    color: var(--color-ink-3);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    transition: color 0.2s ease;
  }
  .scaffold-card:hover .scaffold-card__list-item { color: var(--color-ink-2); }

  .ts-orange-dot {
    color: var(--color-orange-dim);
    font-size: 0.5rem;
  }

  /* Tech Grid */
  .ts-tech-header {
    margin-bottom: 3rem;
  }

  .tech-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    width: 100%;
  }

  .tech-card {
    padding: 1.5rem;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .tech-card__title {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-ink);
    margin-bottom: 0.625rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .tech-card__tagline {
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--color-ink-3);
  }

  @media (max-width: 960px) {
    .tech-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 720px) {
    .scaffold-grid { grid-template-columns: 1fr; }
    .ts-section { padding: 6rem 1.5rem; }
  }

  @media (max-width: 480px) {
    .tech-grid { grid-template-columns: 1fr; }
  }
</style>
