---
const scaffoldTypes = [
  {
    label: "RUST API",
    description: "A production-ready Axum web server with async handlers, typed errors, and structured logging.",
    items: ["axum", "tokio", "sqlx / seaorm", "jwt (optional)"],
    featured: false,
  },
  {
    label: "NEXT.JS APP",
    description: "A full Next.js 15 application with App Router, TypeScript, and optional Tailwind CSS.",
    items: ["next.js 15", "typescript", "tailwind (optional)", "app router"],
    featured: false,
  },
  {
    label: "FULL-STACK",
    description: "Both together — a Rust/Axum API and a Next.js frontend, wired up and ready to ship.",
    items: ["axum + next.js", "sqlx / seaorm", "jwt auth", "typescript"],
    featured: true,
  },
];

const technologies = [
  { name: "axum",       tagline: "Ergonomic async Rust web framework built on Tokio and Tower." },
  { name: "next.js",    tagline: "React framework with App Router, SSR, and streaming." },
  { name: "sqlx",       tagline: "Compile-time checked SQL queries. No ORM overhead." },
  { name: "seaorm",     tagline: "Async, dynamic ORM for Rust. An alternative to SQLx." },
  { name: "postgresql", tagline: "The world's most advanced open-source relational database." },
  { name: "mysql",      tagline: "High-performance, widely-used relational database." },
  { name: "sqlite",     tagline: "Zero-config embedded database. Perfect for development." },
  { name: "jwt auth",   tagline: "Stateless authentication tokens. Full middleware included." },
];
---

<section class="below-fold py-24 px-8 border-b border-border">
  <div class="max-w-[1200px] mx-auto">

    <!-- Section header -->
    <div class="h-px bg-border-2 mb-8 w-full"></div>
    <div class="flex items-center gap-2.5 mb-3">
      <span class="text-orange text-[0.75rem] leading-none" aria-hidden="true">◆</span>
      <h2 class="font-mono text-[0.75rem] font-semibold uppercase tracking-[0.12em] text-ink-3">
        EVERYTHING YOU NEED
      </h2>
    </div>
    <p class="text-[1.0625rem] leading-[1.6] text-ink-2 max-w-[560px] mb-14">
      Pick the pieces. Skip the rest. Every choice is made in the interactive
      wizard — no config files, no guesswork.
    </p>

    <!-- Scaffold type cards — mosaic grid (gap: 1px trick) -->
    <div class="grid grid-cols-3 gap-px bg-border-2 border border-border-2 mb-20 rounded-xl overflow-hidden">
      {scaffoldTypes.map((type) => (
        <div class={`relative flex flex-col gap-5 p-8 transition-all duration-200
          ${type.featured
            ? "bg-surface-2 border-t-2 border-t-orange hover:bg-surface-3 [box-shadow:0_0_0_1px_rgba(244,67,54,0.12),inset_0_1px_0_rgba(244,67,54,0.15)]"
            : "bg-surface hover:bg-surface-2 hover:[box-shadow:inset_2px_0_0_var(--color-orange),0_0_0_1px_rgba(244,67,54,0.08),0_4px_24px_rgba(0,0,0,0.5)]"
          }`}>

          {type.featured && (
            <>
              <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(244,67,54,0.04)_0%,transparent_60%)] pointer-events-none"></div>
              <div class="absolute top-2 right-2 px-2.5 py-1
                          font-mono text-[0.5625rem] font-semibold text-white
                          uppercase tracking-[0.08em] rounded-md
                          bg-orange">
                ★ recommended
              </div>
            </>
          )}

          <div class="font-mono text-[0.9375rem] font-semibold text-ink tracking-[0.02em]">
            {type.label}
          </div>

          <p class="text-[0.875rem] leading-[1.55] text-ink-3 flex-1">
            {type.description}
          </p>

          <ul class="group flex flex-col gap-2.5 pt-3.5 border-t border-border list-none mt-auto">
            {type.items.map((item) => (
              <li class="flex items-center gap-1.5 font-mono text-[0.75rem] text-ink-3 hover:text-ink-2 transition-colors duration-150">
                <span class="text-orange text-[0.5rem] shrink-0" aria-hidden="true">◆</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Tech grid header -->
    <div class="flex items-center gap-2.5 mb-6">
      <span class="text-green text-[0.75rem] leading-none" aria-hidden="true">—</span>
      <h3 class="font-mono text-[0.75rem] font-semibold uppercase tracking-[0.12em] text-ink-3">
        TECHNOLOGIES INCLUDED
      </h3>
    </div>

    <!-- Tech cards — mosaic grid -->
    <div class="grid grid-cols-4 gap-px bg-border-2 border border-border-2 rounded-xl overflow-hidden">
      {technologies.map((tech) => (
        <div class="group flex flex-col gap-3.5 p-6 bg-surface
                    border-t border-transparent
                    group-hover:border-t-orange/20
                    hover:bg-surface-3
                    hover:[box-shadow:inset_0_0_0_1px_rgba(255,255,255,0.05)]
                    transition-all duration-200">
          <div class="flex items-center gap-[0.4375rem] font-mono text-[0.8125rem] font-semibold text-ink group-hover:text-white transition-colors duration-200">
            <span class="text-orange text-[0.625rem] shrink-0 group-hover:text-orange transition-colors duration-200" aria-hidden="true">◆</span>
            {tech.name}
            <span class="text-orange text-[0.625rem] opacity-0 group-hover:opacity-100 transition-opacity duration-200 ml-auto" aria-hidden="true">→</span>
          </div>
          <p class="text-[0.8125rem] leading-[1.5] text-ink-3 group-hover:text-ink-2 transition-colors duration-200">{tech.tagline}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  @media (max-width: 960px) {
    .grid-cols-4 { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 720px) {
    .grid-cols-3 { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    section { padding-left: 1.25rem; padding-right: 1.25rem; padding-top: 3.5rem; padding-bottom: 3.5rem; }
    .grid-cols-4 { grid-template-columns: 1fr; }
  }
</style>
