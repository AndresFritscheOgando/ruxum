---
const features = [
  {
    marker: "01",
    title: "Zero boilerplate",
    body: "Start with a complete, production-ready project structure. Typed errors, structured logging, env config, and CORS middleware are all wired up on day zero.",
  },
  {
    marker: "02",
    title: "Type-safe end-to-end",
    body: "Rust's compile-time guarantees on the backend. TypeScript on the frontend. Two type systems working together so runtime surprises stay rare.",
  },
  {
    marker: "03",
    title: "Your choices, instantly",
    body: "Pick your database, ORM, authentication, and scaffold type in an interactive wizard. You answer; the scaffolder builds the exact project you described.",
  },
  {
    marker: "04",
    title: "Deploy-ready from the start",
    body: "Structured tracing with tracing-subscriber, environment-aware config via dotenvy, and tower-http middleware — the production checklist is already checked.",
  },
];
---

<section class="features-section">
  <div class="features-inner">

    <!-- Section header -->
    <div class="features-header">
      <div class="ts-badge mb-4">
        <span class="ts-badge__icon" aria-hidden="true">◆</span>
        <span class="ts-badge__text">Core Principles</span>
      </div>
      <h2 class="features-headline text-gradient-forge">Skip the scaffolding tax.</h2>
      <p class="features-description">
        Setting up a modern Rust web server is tedious. Ruxum handles the
        framework wiring, logging, database config, and auth so you can
        focus on your product.
      </p>
    </div>

    <!-- Feature cards grid -->
    <div class="features-grid">
      {features.map((f) => (
        <div class="machined-card feature-card group">
          <div class="feature-card-accent" aria-hidden="true"></div>
          <span class="feature-card-marker font-mono">{f.marker}</span>
          <h3 class="feature-card-title">{f.title}</h3>
          <p class="feature-card-body">{f.body}</p>
        </div>
      ))}
    </div>

    <!-- Bottom CTA row -->
    <div class="features-footer">
      <a href="/docs/introduction" class="features-link-primary">
        Read the docs <span class="ml-1 opacity-50">→</span>
      </a>
      <span class="features-footer-divider"></span>
      <a href="/docs/scaffold/fullstack" class="features-link-secondary">
        Full-stack guide <span class="ml-1 opacity-50">→</span>
      </a>
    </div>

  </div>
</section>

<style>
  .features-section {
    position: relative;
    padding: 10rem 3rem;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-canvas);
    overflow: hidden;
  }

  .features-section::after {
    content: "";
    position: absolute;
    bottom: -100px;
    left: 50%;
    width: 800px;
    height: 200px;
    background: radial-gradient(ellipse at center, var(--color-orange-embers) 0%, transparent 70%);
    transform: translateX(-50%);
    pointer-events: none;
    z-index: 0;
  }

  .features-inner {
    position: relative;
    max-width: 860px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    z-index: 1;
  }

  .features-header {
    margin-bottom: 5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .ts-badge {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .ts-badge__icon {
    color: var(--color-orange);
    font-size: 0.75rem;
    filter: drop-shadow(0 0 8px var(--color-orange-molten));
  }

  .ts-badge__text {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-ink-4);
  }

  .features-headline {
    font-family: var(--font-sans);
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 1.25rem;
  }

  .features-description {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-ink-2);
    max-width: 560px;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    width: 100%;
    gap: 1.25rem;
    margin-bottom: 4rem;
  }

  .feature-card {
    padding: 3.5rem 2.5rem;
    border-radius: 12px;
    gap: 1.5rem;
  }

  .feature-card-accent {
    position: absolute;
    left: 0;
    top: 2.5rem;
    bottom: 2.5rem;
    width: 2px;
    background: transparent;
    border-radius: 99px;
    transition: background 0.3s ease;
  }
  .feature-card:hover .feature-card-accent {
    background: var(--color-orange-molten);
    box-shadow: 0 0 12px var(--color-orange-molten);
  }

  .feature-card-marker {
    font-size: 0.6875rem;
    color: var(--color-ink-4);
    letter-spacing: 0.1em;
    tabular-nums: true;
  }

  .feature-card-title {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: -0.01em;
    line-height: 1.3;
    transition: color 0.3s ease;
  }
  .feature-card:hover .feature-card-title {
    color: #fff;
    text-shadow: 0 0 15px rgba(255,255,255,0.1);
  }

  .feature-card-body {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-ink-3);
    transition: color 0.3s ease;
  }
  .feature-card:hover .feature-card-body {
    color: var(--color-ink-2);
  }

  .features-footer {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .features-link-primary {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-orange);
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .features-link-primary:hover { 
    color: var(--color-orange-hi);
    transform: translateX(2px);
  }

  .features-footer-divider {
    width: 1px;
    height: 1rem;
    background: var(--color-border-2);
  }

  .features-link-secondary {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-ink-3);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .features-link-secondary:hover { color: var(--color-ink-2); }

  @media (max-width: 720px) {
    .features-grid { grid-template-columns: 1fr; }
    .features-section { padding: 6rem 1.5rem; }
    .features-headline { font-size: 2rem; }
  }
</style>
