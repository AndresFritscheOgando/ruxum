---
const features = [
  {
    marker: "01",
    title: "Zero boilerplate",
    body: "Start with a complete, production-ready project structure. Typed errors, structured logging, env config, and CORS middleware are all wired up on day zero.",
  },
  {
    marker: "02",
    title: "Type-safe end-to-end",
    body: "Rust's compile-time guarantees on the backend. TypeScript on the frontend. Two type systems working together so runtime surprises stay rare.",
  },
  {
    marker: "03",
    title: "Your choices, instantly",
    body: "Pick your database, ORM, authentication, and scaffold type in an interactive wizard. You answer; the scaffolder builds the exact project you described.",
  },
  {
    marker: "04",
    title: "Deploy-ready from the start",
    body: "Structured tracing with tracing-subscriber, environment-aware config via dotenvy, and tower-http middleware — the production checklist is already checked.",
  },
];
---

<section class="below-fold py-28 px-8 border-b border-border">
  <div class="max-w-[1200px] mx-auto">

    <!-- Section header: type-driven hierarchy, no decorative symbols -->
    <p class="font-sans text-[0.75rem] font-semibold uppercase tracking-[0.1em] text-ink-4 mb-4">
      Why Ruxum
    </p>
    <h2 class="font-sans text-[1.375rem] font-semibold text-ink tracking-[-0.02em] leading-[1.3] max-w-[480px] mb-4">
      Skip the scaffolding tax.
    </h2>
    <p class="text-[1rem] leading-[1.7] text-ink-2 max-w-[520px] mb-20">
      Setting up a modern Rust web server is tedious. Ruxum handles the
      framework wiring, logging, database config, and auth so you can
      focus on your product.
    </p>

    <!-- Feature cards — 2×2 grid, warm cards, clean dividers -->
    <div class="features-grid grid grid-cols-2 border border-border rounded-xl overflow-hidden">
      {features.map((f, i) => (
        <div class="group card-warm relative flex flex-col gap-7 p-10 bg-[#1c1410]
                    hover:bg-surface-3
                    transition-all duration-200">

          <!-- Left terracotta accent bar on hover -->
          <div class="absolute left-0 top-8 bottom-8 w-[2px] bg-orange/0
                      group-hover:bg-orange/30 transition-all duration-200 rounded-full"
               aria-hidden="true"></div>

          <!-- Number: structural, very dim -->
          <span class="font-mono text-[0.6875rem] text-ink-4 tabular-nums">
            {f.marker}
          </span>

          <!-- Feature title: sans-serif for reading clarity -->
          <h3 class="font-sans text-[1.0625rem] font-semibold text-ink tracking-[-0.02em]
                     leading-[1.3] group-hover:text-white transition-colors duration-200">
            {f.title}
          </h3>

          <p class="text-[0.9375rem] leading-[1.7] text-ink-2">
            {f.body}
          </p>
        </div>
      ))}
    </div>

    <!-- Bottom CTA row -->
    <div class="mt-10 flex items-center gap-3">
      <a href="/introduction" class="font-sans text-[0.875rem] text-orange hover:text-orange/80 no-underline transition-colors duration-150">
        Read the docs →
      </a>
      <span class="w-px h-3.5 bg-border-2"></span>
      <a href="/scaffold/fullstack" class="font-sans text-[0.875rem] text-ink-3 hover:text-ink-2 no-underline transition-colors duration-150">
        Full-stack guide →
      </a>
    </div>

  </div>
</section>

<style>
  /* Dividers between cards without gap-px hack */
  .features-grid > *:nth-child(odd) {
    border-right: 1px solid var(--color-border);
  }
  .features-grid > *:nth-child(n+3) {
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 720px) {
    .features-grid { grid-template-columns: 1fr; }
    .features-grid > *:nth-child(odd) { border-right: none; }
    .features-grid > *:nth-child(n+2) { border-top: 1px solid var(--color-border); }
    section { padding-top: 4rem; padding-bottom: 4rem; }
  }
  @media (max-width: 480px) {
    section { padding-left: 1.25rem; padding-right: 1.25rem; }
  }
</style>
