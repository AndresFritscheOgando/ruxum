---
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/Head.astro';

const { entry } = Astro.props;
const slug = entry?.id ?? '';

const siteUrl = 'https://create-ruxum-app.vercel.app';

const pageMap: Record<string, { section: string; label: string }> = {
  introduction:                  { section: 'Getting Started',  label: 'Introduction'    },
  installation:                  { section: 'Getting Started',  label: 'Installation'    },
  'scaffold/rust':               { section: 'Scaffold Types',   label: 'Rust Axum API'   },
  'scaffold/nextjs':             { section: 'Scaffold Types',   label: 'Next.js App'     },
  'scaffold/fullstack':          { section: 'Scaffold Types',   label: 'Full-stack'      },
  'configuration/database':      { section: 'Configuration',    label: 'Database'        },
  'configuration/authentication':{ section: 'Configuration',    label: 'Authentication'  },
};

const info = pageMap[slug];

const items = info
  ? [
      { position: 1, name: 'Home',         item: `${siteUrl}/` },
      { position: 2, name: info.section,   item: `${siteUrl}/` },
      { position: 3, name: info.label,     item: `${siteUrl}/${slug}/` },
    ]
  : [
      { position: 1, name: 'Home',             item: `${siteUrl}/` },
      { position: 2, name: entry?.data?.title ?? slug, item: `${siteUrl}/${slug}/` },
    ];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map(i => ({ '@type': 'ListItem', ...i })),
};

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'create-ruxum-app',
  url: siteUrl,
  logo: `${siteUrl}/favicon.svg`,
  sameAs: [
    'https://github.com/AndresFritscheOgando/ruxum',
    'https://www.npmjs.com/package/create-ruxum-app',
  ],
};
---

<Default {...Astro.props} />
<meta property="og:image" content={`${siteUrl}/og-image.png`} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content={`${siteUrl}/og-image.png`} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
